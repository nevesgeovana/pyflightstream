# Local-only material: manuals, research geometry (hard invariants 1 and 5)
_private/

# Licensed or binary documents never enter Git
*.pdf
*.ipynb

# Python build and cache artifacts
__pycache__/
*.pyc
build/
dist/
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/

# mkdocs build output
site/

# Tier 2 probe scratch (scripts and logs); the compat report under
# reports/compat/ is the committed evidence
probe_runs/

# Tier 3 physics and drift scratch (geometry, scripts, solver
# outputs); the reports under reports/physics/ are the committed
# evidence
physics_runs/
drift_runs*/

# LaTeX build artifacts of the beamer guide; the built pdf never
# enters Git (repository guard), only guide/*.tex is committed
guide/*.pdf
guide/*.aux
guide/*.log
guide/*.nav
guide/*.out
guide/*.snm
guide/*.toc
guide/*.fls
guide/*.fdb_latexmk
guide/*.synctex.gz
guide/*.vrb
