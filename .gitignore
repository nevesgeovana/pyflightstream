# Local-only material: manuals, research geometry (hard invariants 1 and 5)
_private/

# Licensed or binary documents never enter Git
*.pdf
*.ipynb

# Python build and cache artifacts
__pycache__/
*.pyc
build/
dist/
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/

# mkdocs build output
site/

# Local run scratch, one root for every tier (runs/probes, runs/physics,
# runs/drift, runs/fsi, campaign workspaces); the committed evidence is
# the reports/ tree, never the scratch. Convention recorded at HND-035
# session close; the earlier per-tier roots (probe_runs/, physics_runs/,
# drift_runs*/, fsi_runs/) moved under runs/ the same day.
runs/

# LaTeX build artifacts of the beamer guide; the built pdf never
# enters Git (repository guard), only guide/*.tex is committed
guide/*.pdf
guide/*.aux
guide/*.log
guide/*.nav
guide/*.out
guide/*.snm
guide/*.toc
guide/*.fls
guide/*.fdb_latexmk
guide/*.synctex.gz
guide/*.vrb
